{
  "manifest_version": 3,
  "name": "X(Twitter) Comment Blocker - Auto Hide Spam",
  "version": "1.1",
  "description": "一键净化 X (Twitter) 评论区，自动屏蔽垃圾信息与引流机器人。",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.github.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "设置屏蔽词",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.twitter.com/*",
        "*://*.x.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}